# Omega Point - Production Configuration Template
# Copy this to .env when deploying to production

# Server settings
NODE_ENV=production
PORT=3002
HOST=0.0.0.0
# Leave VITE_API_URL empty - Flask serves everything on same origin in production
VITE_API_URL=

# LLM Provider
API_PROVIDER=openai
OPENAI_API_KEY=your_openai_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here

# Production worker settings
# Adjust based on your server specs
# Rule of thumb: GUNICORN_WORKERS = (2 x CPU cores) + 1
GUNICORN_WORKERS=9
GUNICORN_TIMEOUT=300
MAX_BATCH_WORKERS=15

# Models available in the UI
VITE_IMPROVEMENT_MODELS=GPT-4.1:gpt-4.1,GPT-4o:gpt-4o,GPT-4 Turbo:gpt-4-turbo,Claude 3.5 Sonnet:anthropic/claude-3.5-sonnet
VITE_DEFAULT_IMPROVEMENT_TEMPERATURE=0.7

# Database & Redis
# IMPORTANT: Change DB_PASSWORD from 'changeme' to something secure!
# Use: openssl rand -base64 32 | tr -d "=+/" | cut -c1-24
DATABASE_URL=postgresql://omegapoint:changeme@postgres:5432/omegapoint
DB_PASSWORD=changeme
REDIS_URL=redis://redis:6379/0
SESSION_EXPIRY_DAYS=60

# Research API Keys (optional - free tier works without keys)
# Improves rate limits: 10 req/s with keys vs 3 req/s without
# Get PubMed key: https://www.ncbi.nlm.nih.gov/account/
# Get Semantic Scholar key: https://www.semanticscholar.org/product/api
PUBMED_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
PUBMED_EMAIL=  # Optional: your email for PubMed courtesy

# ============================================================================
# STEP 4 OPTIMIZED CONFIGURATION - PRODUCTION
# ============================================================================
# Step 4 maps "what's needed" (Goals + RAs) to "scientific reality" (evidence)
#
# Production recommendations:
# - Use optimized Step 4 for real citations and caching
# - Set AUTO_INIT=false for lazy loading (faster startup)
# - Monitor cache hit rates in logs
# - Consider GPU if processing many requests
# ============================================================================

# Toggle between optimized (research APIs) and classic (domain mapping)
STEP4_USE_OPTIMIZED=true

# Lazy initialization (recommended for production)
# false = Init on first request (faster startup, slower first request)
# true = Init at startup (slower startup, faster first request)
STEP4_AUTO_INIT=false

# GPU acceleration (set true if GPU available and high volume)
STEP4_USE_GPU=false

# LLM models - Claude 3 Haiku recommended
# Cost: ~$0.30/goal (63% cheaper than GPT-4o)
STEP4_QUERY_MODEL=anthropic/claude-3-haiku
STEP4_FILTER_MODEL=anthropic/claude-3-haiku
STEP4_SYNTHESIS_MODEL=anthropic/claude-3-haiku

# Performance tuning
STEP4_EMBEDDING_BATCH_SIZE=32    # Higher = faster but more memory
STEP4_TARGET_PILLARS=25          # Target pillars per goal
STEP4_DEDUP_THRESHOLD=0.85       # Similarity threshold for deduplication

# Production checklist:
# [ ] Changed DB_PASSWORD to strong random password
# [ ] Set up HTTPS with reverse proxy (nginx/caddy)
# [ ] Configured firewall rules
# [ ] Set up monitoring and logging
# [ ] Configured automated backups
# [ ] Tested with multiple concurrent users
