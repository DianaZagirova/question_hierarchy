# Omega Point - Configuration Template
# Copy this to .env and fill in your actual values

# Basic server settings
NODE_ENV=development
PORT=3002
HOST=0.0.0.0
VITE_API_URL=http://localhost:3002

# Choose your LLM provider: openai or openrouter
API_PROVIDER=openai

# Get your API keys from:
# OpenAI: https://platform.openai.com/api-keys
# OpenRouter: https://openrouter.ai/keys
OPENAI_API_KEY=your_openai_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Worker configuration
# GUNICORN_WORKERS = roughly (2 x CPU cores) + 1
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=300
MAX_BATCH_WORKERS=5

# Which models show up in the node improvement dropdown
# Format: "Display Name:model-id"
VITE_IMPROVEMENT_MODELS=GPT-4.1:gpt-4.1,GPT-4o:gpt-4o,GPT-4 Turbo:gpt-4-turbo,Claude 3.5 Sonnet:anthropic/claude-3.5-sonnet
VITE_DEFAULT_IMPROVEMENT_TEMPERATURE=0.7

# Multi-user session support (requires PostgreSQL + Redis)
# For Docker, use 'postgres' and 'redis' as hostnames
# For local setup, use 'localhost'
DATABASE_URL=postgresql://omegapoint:changeme@postgres:5432/omegapoint
DB_PASSWORD=changeme
REDIS_URL=redis://redis:6379/0
SESSION_EXPIRY_DAYS=60

# Research API Keys (optional - free tier works without keys)
# Improves rate limits: 10 req/s with keys vs 3 req/s without
# Get PubMed key: https://www.ncbi.nlm.nih.gov/account/
# Get Semantic Scholar key: https://www.semanticscholar.org/product/api
PUBMED_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
PUBMED_EMAIL=  # Optional: your email for PubMed courtesy

# ============================================================================
# STEP 4 OPTIMIZED CONFIGURATION
# ============================================================================
# Step 4 maps "what's needed" (Goals + RAs) to "scientific reality" (papers)
# Optimized version uses real research APIs for evidence-based results
#
# Benefits:
# - Real citations from PubMed, Semantic Scholar, OpenAlex
# - Intelligent caching (70-85% hit rate)
# - Cost: ~$0.30/goal (63% cheaper than GPT-4o)
# - Speed: 30-60s first run, 2-5s cached
# ============================================================================

# Toggle between optimized (research APIs) and classic (domain mapping)
STEP4_USE_OPTIMIZED=true

# When to initialize (false = lazy/on-demand, true = at startup)
STEP4_AUTO_INIT=true

# GPU acceleration for embeddings (requires CUDA)
STEP4_USE_GPU=false

# LLM models for different Step 4 phases
# Haiku is fast, cheap, and high quality - recommended
STEP4_QUERY_MODEL=anthropic/claude-3-haiku
STEP4_FILTER_MODEL=anthropic/claude-3-haiku
STEP4_SYNTHESIS_MODEL=anthropic/claude-3-haiku

# Performance tuning
STEP4_EMBEDDING_BATCH_SIZE=32    # Higher = faster but more memory
STEP4_TARGET_PILLARS=25          # Target pillars per goal
STEP4_DEDUP_THRESHOLD=0.85       # Similarity threshold (0-1)
